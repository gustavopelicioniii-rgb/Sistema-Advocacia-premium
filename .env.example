# =============================================
# smart-case-mate — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o arquivo .env no git.

# ── Supabase (obrigatório) ──────────────────
# Encontre em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── Sentry — Observabilidade (opcional) ─────
# Encontre em: sentry.io → Settings → Projects → Client Keys
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ── Edge Functions (configurar no Supabase Dashboard) ─────────────────
# As variáveis abaixo NÃO são prefixadas com VITE_ pois ficam apenas no servidor.
# Configure em: Supabase Dashboard → Edge Functions → Secrets
#
#   ESCAVADOR_API_TOKEN=seu_token_escavador   ← token da API Escavador (server-side only)
#   SUPABASE_SERVICE_ROLE_KEY=...             ← injetado automaticamente pelo Supabase
#   SUPABASE_URL=...                          ← injetado automaticamente pelo Supabase
#   SENTRY_DSN=https://xxxxx@sentry.io/xxxxx ← DSN do Sentry para Edge Functions (opcional)
