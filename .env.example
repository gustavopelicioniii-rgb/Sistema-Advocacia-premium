# ============================================
# SUPABASE CONFIGURATION
# ============================================

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima do Supabase (segura para usar no frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# ESCAVADOR API CONFIGURATION
# ============================================

# ⚠️ IMPORTANTE: Este token NÃO deve ser usado no frontend!
# Ele é configurado como variável de ambiente no Supabase Dashboard
# em: Project Settings → Edge Functions → Environment Variables

# Para desenvolvimento local (NUNCA commitar com valor real):
# ESCAVADOR_TOKEN=seu_token_aqui

# ============================================
# DEVELOPMENT ENVIRONMENT
# ============================================

# Habilitar logs detalhados
DEBUG=true
